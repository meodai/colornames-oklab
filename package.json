{
  "name": "colornames-oklab",
  "version": "0.5.0",
  "description": "4444 color names blue-noise sampled over the Rec2020 gamut in OKLab — evenly spread perceptually, tiered by gamut (sRGB / Display P3 / Rec2020), named by Claude Fable 5.",
  "license": "MIT",
  "author": "meodai",
  "main": "index.cjs",
  "exports": {
    ".": {
      "import": "./index.mjs",
      "require": "./index.cjs",
      "default": "./index.cjs"
    },
    "./colornames-oklab.json": "./colornames-oklab.json"
  },
  "files": [
    "colornames-oklab.json",
    "index.cjs",
    "index.mjs",
    "README.md",
    "LICENSE"
  ],
  "keywords": [
    "color",
    "colors",
    "color-names",
    "oklab",
    "oklch",
    "wide-gamut",
    "display-p3",
    "rec2020",
    "blue-noise",
    "palette"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/meodai/colornames-oklab.git"
  },
  "scripts": {
    "test": "node scripts/test.mjs && node scripts/test-api.mjs && node scripts/audit-basics.mjs && node scripts/audit-families.mjs",
    "sample": "node scripts/sample-points.mjs",
    "sample:more": "node scripts/sample-more.mjs",
    "worksheet": "node scripts/make-worksheet.mjs",
    "build": "node scripts/merge-names.mjs && node scripts/audit-basics.mjs && vite build",
    "validate": "node scripts/merge-names.mjs && node scripts/audit-basics.mjs",
    "dev": "vite"
  },
  "devDependencies": {
    "culori": "^4.0.2",
    "vite": "^7.0.0",
    "three": "^0.164.1"
  }
}
